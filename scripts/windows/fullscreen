#!/usr/bin/env bash
# reload waybar with: pkill -SIGUSR2 waybar
# reload this module with: pkill -RTMIN+1 waybar
TOOLS=$(dirname "$(dirname "$(realpath "$0")")")/tools/functions
# shellcheck source=/home/pncolvr/.config/waybar/scripts/tools/functions
source "$TOOLS"

if hyprctl activewindow 2>/dev/null | grep -q 'pid'; then
    current=$(hyprctl activewindow -j | jq '.fullscreen' 2>/dev/null)
    case $current in
        1) respondWithIcon "" "" "" "";;
        2|3) respondWithIcon "" "" "" "";;
    esac
fi

