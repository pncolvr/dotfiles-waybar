#!/usr/bin/env bash
# reload waybar with: pkill -SIGUSR2 waybar
# reload this module with: pkill -RTMIN+1 waybar
TOOLS=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]:-0}")")")/tools/functions
# shellcheck source=/home/pncolvr/.config/waybar/scripts/tools/functions
source "$TOOLS"

function get_active_window_json() {
    hyprctl activewindow -j 2>/dev/null
}

function get_active_window_address() {
    get_active_window_json | jq -r '.address // empty'
}

function get_active_workspace() {
    hyprctl activeworkspace -j | jq --raw-output '.id'
}

function get_cursor_no_warps() {
    hyprctl getoption cursor:no_warps -j 2>/dev/null | jq -r '.int // 0'
}

function set_cursor_no_warps() {
    hyprctl keyword cursor:no_warps "$1" >/dev/null
}

function is_special_workspace() {
    case $1 in
        3|4|10) return 0;;
        *) return 1;;
    esac
}

function get_clean_title() {
    patterns=("- Vivaldi" "- qutebrowser" "- FreeTube" "- YouTube" "- Google Search" "- Twitch" "- Microsoft Azure")
    text=$(get_active_window_json | jq -r '.title')
    for pat in "${patterns[@]}"; do
        if [[ $text == *" $pat" ]]; then
            text="${text%" $pat"}"
        fi
    done
    echo "${text:0:165}"
}

function escape_pango() {
    sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'
}

function get_info() {
    hyprctl activewindow 2>/dev/null
}

function copy_info() {
    wl-copy "$(get_info)"
}

function handle_action() {
    local ws="$1"
    local class=""
    local clients=""
    case $ws in 
        3|4|10)
            clients=$(list_windows "$1")
            class="workspace-$ws"
            ;;
        *)
            clients=$(get_clean_title)
            class="single";;
    esac 
    if [[ $clients == "null" ]]; then
        clients=""
    fi
    local tooltip
    tooltip=$(get_info)
    respond "$clients" "$tooltip" "$class"
}

function get_ordered_windows() {
    local ws="$1"
    local -a clients
    local -a processed_clients
    local client address class title display_title

    mapfile -t clients < <(
        hyprctl clients -j | jq -r --argjson ws "$ws" --argjson f false \
            '.[] | select(.workspace.id == $ws and .floating == $f) | "\(.address)|\(.class)|\(.title)"'
    )

    for client in "${clients[@]}"; do
        [[ -z "$client" ]] && continue
        IFS="|" read -r address class title <<< "$client"
        display_title=$(handle_title "$ws" "$title" "$class")
        processed_clients+=("$display_title|$address|$class|$title")
    done

    if [[ ${#processed_clients[@]} -eq 0 ]]; then
        return 0
    fi

    printf '%s\n' "${processed_clients[@]}" | sort -t '|' -k1,1
}

function list_windows() {
    local ws="$1"
    local current_address
    local -a sorted_clients
    local spans=""
    local client display_title address class title

    current_address=$(get_active_window_address)
    mapfile -t sorted_clients < <(get_ordered_windows "$ws")

    for client in "${sorted_clients[@]}"; do
        [[ -z "$client" ]] && continue
        IFS="|" read -r display_title address class title <<< "$client"
        if [[ ! $spans == "" ]]; then
            spans+="<span>⸱</span>"
        fi
        spans+=$(echo -n "<span $(handle_selected "$address" "$current_address")>$display_title</span> ")
    done
    spans="${spans% }" # why? because i dont know css well enough
    echo "$spans"
}

function handle_selected() {
    local window=$1
    local current="${2:-$(get_active_window_address)}"

    if [[ "$current" == "$window" ]]; then
        echo 'foreground="#6272a4"'
    fi
}

function ordered_windows_contains_address() {
    local target="$1"
    local client address
    shift

    for client in "$@"; do
        IFS="|" read -r _ address _ <<< "$client"
        if [[ "$address" == "$target" ]]; then
            return 0
        fi
    done

    return 1
}

function get_next_ordered_window_address() {
    local reference_address="$1"
    shift

    local -a ordered_windows=("$@")
    local client address
    local current_index=0
    local next_index=0
    local found=false

    if [[ ${#ordered_windows[@]} -eq 0 ]]; then
        return 0
    fi

    if [[ -z "$reference_address" ]]; then
        IFS="|" read -r _ address _ <<< "${ordered_windows[0]}"
        echo "$address"
        return 0
    fi

    for client in "${ordered_windows[@]}"; do
        IFS="|" read -r _ address _ <<< "$client"
        if [[ "$address" == "$reference_address" ]]; then
            found=true
            break
        fi
        ((current_index += 1))
    done

    if [[ "$found" == true ]]; then
        next_index=$(((current_index + 1) % ${#ordered_windows[@]}))
    fi

    IFS="|" read -r _ address _ <<< "${ordered_windows[$next_index]}"
    echo "$address"
}

function get_prev_ordered_window_address() {
    local reference_address="$1"
    shift

    local -a ordered_windows=("$@")
    local client address
    local current_index=0
    local prev_index=0
    local found=false

    if [[ ${#ordered_windows[@]} -eq 0 ]]; then
        return 0
    fi

    if [[ -z "$reference_address" ]]; then
        IFS="|" read -r _ address _ <<< "${ordered_windows[-1]}"
        echo "$address"
        return 0
    fi

    for client in "${ordered_windows[@]}"; do
        IFS="|" read -r _ address _ <<< "$client"
        if [[ "$address" == "$reference_address" ]]; then
            found=true
            break
        fi
        ((current_index += 1))
    done

    if [[ "$found" == true ]]; then
        prev_index=$(((current_index - 1 + ${#ordered_windows[@]}) % ${#ordered_windows[@]}))
    fi

    IFS="|" read -r _ address _ <<< "${ordered_windows[$prev_index]}"
    echo "$address"
}

function get_special_workspace_reference_address() {
    local active_address="$1"
    shift

    local -a ordered_windows=("$@")

    if ordered_windows_contains_address "$active_address" "${ordered_windows[@]}"; then
        echo "$active_address"
        return 0
    fi
}

function move_next_special_workspace_window() {
    local ws="$1"
    local current_address reference_address next_address
    local -a ordered_windows

    current_address=$(get_active_window_address)
    mapfile -t ordered_windows < <(get_ordered_windows "$ws")

    if [[ ${#ordered_windows[@]} -eq 0 ]]; then
        return 0
    fi

    reference_address=$(get_special_workspace_reference_address "$current_address" "${ordered_windows[@]}")
    next_address=$(get_next_ordered_window_address "$reference_address" "${ordered_windows[@]}")

    [[ -z "$next_address" ]] && return 0

    hyprctl dispatch focuswindow "address:$next_address" >/dev/null
}

function move_prev_special_workspace_window() {
    local ws="$1"
    local current_address reference_address prev_address
    local -a ordered_windows

    current_address=$(get_active_window_address)
    mapfile -t ordered_windows < <(get_ordered_windows "$ws")

    if [[ ${#ordered_windows[@]} -eq 0 ]]; then
        return 0
    fi

    reference_address=$(get_special_workspace_reference_address "$current_address" "${ordered_windows[@]}")
    prev_address=$(get_prev_ordered_window_address "$reference_address" "${ordered_windows[@]}")

    [[ -z "$prev_address" ]] && return 0

    hyprctl dispatch focuswindow "address:$prev_address" >/dev/null
}

function active_window_has_group() {
    get_active_window_json | jq -e '(.grouped // []) | length > 1' >/dev/null
}

function handle_move_next() {
    local ws

    ws=$(get_active_workspace)

    if is_special_workspace "$ws"; then
        move_next_special_workspace_window "$ws"
        return 0
    fi

    if active_window_has_group; then
        hyprctl dispatch changegroupactive f >/dev/null
        return 0
    fi

    hyprctl dispatch cyclenext tiled >/dev/null
}

function move_next() {
    local original_no_warps
    local status

    original_no_warps=$(get_cursor_no_warps)
    set_cursor_no_warps 1

    handle_move_next
    status=$?

    set_cursor_no_warps "$original_no_warps"

    return $status
}

function handle_move_prev() {
    local ws

    ws=$(get_active_workspace)

    if is_special_workspace "$ws"; then
        move_prev_special_workspace_window "$ws"
        return 0
    fi

    if active_window_has_group; then
        hyprctl dispatch changegroupactive b >/dev/null
        return 0
    fi

    hyprctl dispatch cyclenext prev tiled >/dev/null
}

function move_prev() {
    local original_no_warps
    local status

    original_no_warps=$(get_cursor_no_warps)
    set_cursor_no_warps 1

    handle_move_prev
    status=$?

    set_cursor_no_warps "$original_no_warps"

    return $status
}

function handle_title() {
    ws=$1
    window_title=$2
    class=$3
    case $ws in
        3) handle_workspace3_title "$class" "$window_title";;
        4) handle_workspace4_title "$class" "$window_title";;
        10) echo "$window_title";;
    esac
}

function handle_workspace3_title(){
    class=$1
    window_title=$2
    if [[ "$class" == "vivaldi-teams.microsoft.com__v2_-lt" ]]; then
        echo "teams"
    else
        echo "$class"
    fi
}

function handle_workspace4_title(){
    class=$1
    window_title=$2
    if [[ "$class" == "code" ]]; then
        echo "${window_title%%-*}"
    else
        echo "$window_title"
    fi
}

function handle_event() {
    ws=$(get_active_workspace)
    handle_action "$ws"
}

case $1 in 
    list) handle_event;;
    copy) copy_info;;
    move-next) move_next;;
    move-previous) move_prev;;
esac